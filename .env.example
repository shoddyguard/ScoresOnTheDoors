# Copy to .env.local for local development
# Never commit .env.local or .env

# SQLite database path. Relative file: paths are resolved relative to the prisma/
# schema directory (Prisma's default), so "file:./dev.db" -> prisma/dev.db. Do NOT
# write "file:./prisma/dev.db" -- that resolves to prisma/prisma/dev.db and breaks.
# Dev:    file:./dev.db
# Docker: file:/data/app.db
DATABASE_URL="file:./dev.db"

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Your app's public URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Optional: set to "true" to disable the auto-sync background job (e.g. in tests)
DISABLE_SYNC="false"

# Optional: UID/GID the container process runs as (Docker only, defaults to 1001/1001)
# PUID=1001
# PGID=1001
